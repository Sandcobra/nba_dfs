# NBA DFS Model — Environment Variables
# Copy this file to .env and fill in your API keys

# Vegas/Odds data — FREE tier available: https://the-odds-api.com
THE_ODDS_API_KEY=your_key_here

# Rotowire injury/news feed — paid subscription
ROTOWIRE_API_KEY=

# SportRadar (official NBA data partner) — expensive but most complete
SPORTRADAR_API_KEY=

# RotoGrinders projections API — paid subscription
RG_PROJECTIONS_KEY=

# Anthropic (for AI-powered insight generation)
ANTHROPIC_API_KEY=your_anthropic_key_here

# Sportsline projections
SPORTSLINE_API_KEY=
